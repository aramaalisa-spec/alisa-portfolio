---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import PostList from '../components/PostList.astro';
import Social from '../components/Social.astro';

import { getSite } from '../utils/consts';
import ProjectList from '../components/ProjectList.astro';

const site = await getSite();
---

<PageLayout
	title={site.author.name || 'Alisa Arama'}
>
	<Hero
		title={site.author.name || 'Alisa Arama'}
		description={site.author.bio || 'Welcome to my personal website.'}
		role={site.author.role}
		location={site.author.location}
		actions={[
			{ label: 'Portfolio', href: '/blog' },
			{ label: 'Resume', href: 'https://resume.domain.com' },
		]}
	/>

	

	<PostList
		heading="Portfolio"
		limit={6}
		viewAllHref="/blog"
	/>

</PageLayout>